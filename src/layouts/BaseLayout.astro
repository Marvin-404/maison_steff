---
import "../styles/global.css";
import { site } from "../data/site";
import { withBase } from "../utils/asset";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(withBase("images/real/fresa-clasica-fruta.jpg"), Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var nav = window.navigator || {};
        var connection = nav.connection || nav.mozConnection || nav.webkitConnection;
        var reduceMotion = false;

        if (window.matchMedia) {
          reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        }

        var compactMotion =
          reduceMotion ||
          !!(connection && connection.saveData) ||
          (!!nav.deviceMemory && nav.deviceMemory <= 2) ||
          (!!nav.hardwareConcurrency && nav.hardwareConcurrency <= 2);

        root.className += " motion-full motion-intro motion-preload";
        if (reduceMotion) {
          root.className += " motion-reduced";
        }
        if (compactMotion) {
          root.className += " motion-compact";
        }
        if (window.history && "scrollRestoration" in window.history) {
          history.scrollRestoration = "manual";
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fff8f2" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      as="image"
      href={withBase("images/optimized/maison-steff-logo-520.webp")}
      type="image/webp"
      fetchpriority="high"
    />
    <link rel="icon" type="image/png" href={withBase("images/real/maison-steff-logo.png")} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <slot />
    <script is:inline>
      (function () {
        var progress = document.querySelector("#page-progress");
        var progressFrame = 0;
        var raf = window.requestAnimationFrame || function (callback) { return window.setTimeout(callback, 16); };

        if (!progress) return;

        var updateProgress = function () {
          if (progressFrame) return;
          progressFrame = raf(function () {
            var total = document.documentElement.scrollHeight - window.innerHeight;
            var scrollTop = window.pageYOffset || document.documentElement.scrollTop || 0;
            var value = total > 0 ? Math.min(1, scrollTop / total) : 0;
            progress.style.transform = "scaleX(" + value + ")";
            progressFrame = 0;
          });
        };

        window.addEventListener("scroll", updateProgress, { passive: true });
        updateProgress();
      })();
    </script>
    <script>
      const root = document.documentElement;

      if (root.classList.contains("motion-full")) {
        import("../scripts/motion.ts").catch(() => {
          root.classList.remove("motion-full", "motion-intro", "motion-preload");
          root.classList.add("motion-lite");
        });
      }
    </script>
  </body>
</html>
