---
import ProductCard from "./ProductCard.astro";
import { availableProducts, catalogFilters } from "../data/products";
import { proposals } from "../data/proposals";
import OptimizedPicture from "./OptimizedPicture.astro";
---

<section class="section catalog-section" id="catalogo">
  <div class="container">
    <div class="section-heading split-heading" data-reveal>
      <div>
        <p class="eyebrow">La colección</p>
        <h2>Elige tu favorito.</h2>
      </div>
      <p>Preparados por encargo para regalar, celebrar o consentir.</p>
    </div>
    <div class="filter-row" role="group" aria-label="Filtrar productos">
      {catalogFilters.map((filter, index) => (
        <button
          class:list={["filter-button", { active: index === 0 }]}
          type="button"
          data-filter={filter.value}
          aria-pressed={index === 0 ? "true" : "false"}
        >
          {filter.label}
        </button>
      ))}
    </div>
    <div class="product-grid">
      {availableProducts.map((product) => <ProductCard product={product} />)}
    </div>
    <div class="proposal-panel" data-reveal>
      <div class="proposal-heading">
        <div>
          <p class="eyebrow">Ideas visuales</p>
          <h3>Desliza para ver más propuestas.</h3>
        </div>
        <p>Elige una referencia o envía una idea parecida por Instagram para confirmar si se puede realizar.</p>
      </div>
      <div class="proposal-rail" aria-label="Propuestas visuales de pasteles" tabindex="0">
        {proposals.map((proposal) => (
          <button class="proposal-card" type="button" data-design={proposal.title}>
            <OptimizedPicture
              src={proposal.image}
              alt={proposal.alt}
              width="720"
              height="760"
              loading="lazy"
              sizes="(min-width: 64rem) 15rem, 62vw"
            />
            <span>
              <small>{proposal.category}</small>
              <strong>{proposal.title}</strong>
            </span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter-button");
  const productCards = document.querySelectorAll<HTMLElement>(".product-card");
  const motionSafe = !window.matchMedia || !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const productFilters = new Map(
    [...productCards].map((card) => [card, new Set(card.dataset.filters ? card.dataset.filters.split(" ") : [])]),
  );

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const filter = button.dataset.filter;
      filterButtons.forEach((item) => {
        const active = item === button;
        item.classList.toggle("active", active);
        item.setAttribute("aria-pressed", String(active));
      });
      productCards.forEach((card) => {
        const filters = productFilters.get(card);
        const visible = filter === "all" || Boolean(filters && filters.has(filter || ""));
        card.hidden = !visible;
      });
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".reserve-product").forEach((button) => {
    button.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("select-product", { detail: button.dataset.product }));
      const reservation = document.querySelector("#reservar");
      if (reservation) reservation.scrollIntoView({ behavior: motionSafe ? "smooth" : "auto" });
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".proposal-card").forEach((button) => {
    button.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("select-design", { detail: button.dataset.design }));
      const reservation = document.querySelector("#reservar");
      if (reservation) reservation.scrollIntoView({ behavior: motionSafe ? "smooth" : "auto" });
    });
  });
</script>
