---
import { availableProducts } from "../data/products";
import { site } from "../data/site";
import OptimizedPicture from "./OptimizedPicture.astro";

const fillingOptions = [
  { label: "Chantilly", surcharge: 0 },
  { label: "Chocolate", surcharge: 15 },
  { label: "Jalea de fresa", surcharge: 10 },
  { label: "Galleta Oreo", surcharge: 15 },
  { label: "Fruta: manzana o fresa", surcharge: 20 },
];
---

<section class="section reservation-section" id="reservar">
  <div class="container guided-reservation">
    <div class="reservation-intro" data-reveal>
      <p class="eyebrow eyebrow-light">Reserva fácil</p>
      <h2>Elige. Copia.<br />Reserva.</h2>
      <p>Prepara tu solicitud y envíala por Instagram.</p>
    </div>

    <form class="guided-form" id="reservation-form" data-instagram={site.instagramDmUrl} data-reveal>
      <div class="step-header">
        <div>
          <span class="step-kicker">Preparar mi solicitud</span>
          <strong id="step-title">Elige tu favorito</strong>
        </div>
        <span class="step-counter"><b id="current-step">01</b> / 03</span>
      </div>
      <div class="step-progress" aria-hidden="true"><span id="step-progress-bar"></span></div>

      <section class="reservation-step active" data-step-panel="1" aria-labelledby="step-one-title">
        <div class="step-copy">
          <span>Primer paso</span>
          <h3 id="step-one-title" tabindex="-1">¿Qué quieres regalar o disfrutar?</h3>
          <p>Selecciona una opción. Podrás consultar personalizaciones por mensaje.</p>
        </div>
        <div class="product-choice-grid">
          {availableProducts.map((product) => (
            <label class="product-choice" data-product-id={product.id}>
              <input type="radio" name="product" value={product.name} required />
              <OptimizedPicture
                src={product.image}
                alt={product.alt}
                width="680"
                height="760"
                loading="lazy"
                sizes="(min-width: 64rem) 16rem, (min-width: 42rem) 33vw, 50vw"
              />
              <span>
                <small>{product.badge}</small>
                <strong>{product.name}</strong>
                <em>{product.price}</em>
              </span>
              <i aria-hidden="true">✓</i>
            </label>
          ))}
        </div>
        <div class="step-footer">
          <p>Preparado por encargo y sujeto a disponibilidad.</p>
          <button class="button next-step" type="button" data-next="2">Continuar <span>→</span></button>
        </div>
      </section>

      <section class="reservation-step" data-step-panel="2" aria-labelledby="step-two-title" hidden>
        <div class="step-copy">
          <span>Segundo paso</span>
          <h3 id="step-two-title" tabindex="-1">Cuéntanos un poco más.</h3>
          <p>Elige relleno, fecha y los detalles del diseño para revisar tu solicitud.</p>
        </div>
        <div class="detail-fields">
          <div class="field quantity-field">
            <label for="quantity">Cantidad</label>
            <div class="quantity-control">
              <button type="button" data-quantity="-1" aria-label="Disminuir cantidad">−</button>
              <input id="quantity" name="quantity" type="number" min="1" value="1" required />
              <button type="button" data-quantity="1" aria-label="Aumentar cantidad">+</button>
            </div>
          </div>
          <div class="field">
            <label for="date">Fecha deseada</label>
            <input id="date" name="date" type="date" required />
          </div>
        </div>
        <fieldset class="choice-field">
          <legend>Elige el relleno</legend>
          <div class="choice-chips">
            {fillingOptions.map((option, index) => (
              <label>
                <input
                  type="radio"
                  name="filling"
                  value={option.label}
                  data-surcharge={option.surcharge}
                  checked={index === 0}
                />
                <span>{option.surcharge > 0 ? `${option.label} +L ${option.surcharge}` : `${option.label} sin recargo`}</span>
              </label>
            ))}
          </div>
          <p class="field-note">El recargo del relleno se suma por unidad. El precio final se confirma por Instagram.</p>
        </fieldset>
        <fieldset class="choice-field">
          <legend>¿Para qué ocasión?</legend>
          <div class="choice-chips">
            {["Cumpleaños", "Aniversario", "Detalle especial", "Reunión", "Solo porque sí"].map((occasion, index) => (
              <label>
                <input type="radio" name="occasion" value={occasion} checked={index === 0} />
                <span>{occasion}</span>
              </label>
            ))}
          </div>
        </fieldset>
        <div class="field">
          <label for="dedication">Mensaje, diseño o idea especial <span>opcional</span></label>
          <textarea id="dedication" name="dedication" rows="3" placeholder="Ejemplo: Happy Birthday Ana, flores rosadas, corazones o una idea parecida a mi referencia"></textarea>
          <p class="field-note">Por ahora trabajamos principalmente con chantilly. Si tienes una imagen de referencia, envíala por Instagram para confirmar si se puede realizar; más adelante se consultarán opciones con fondant y colores más vivos.</p>
        </div>
        <div class="step-footer">
          <button class="text-button previous-step" type="button" data-previous="1"><span>←</span> Volver</button>
          <button class="button next-step" type="button" data-next="3">Ver mi resumen <span>→</span></button>
        </div>
      </section>

      <section class="reservation-step" data-step-panel="3" aria-labelledby="step-three-title" hidden>
        <div class="step-copy">
          <span>Último paso</span>
          <h3 id="step-three-title" tabindex="-1">Tu solicitud está casi lista.</h3>
          <p>Revisa el resumen. Maison Steff confirmará disponibilidad y precio final personalmente.</p>
        </div>
        <div class="field">
          <label for="customer-name">¿A nombre de quién preparamos la solicitud?</label>
          <input id="customer-name" name="customerName" type="text" autocomplete="name" placeholder="Tu nombre" required />
        </div>
        <fieldset class="choice-field">
          <legend>¿Cómo prefieres recibirlo?</legend>
          <div class="choice-chips">
            <label>
              <input type="radio" name="delivery" value="Recoger" checked />
              <span>Recoger</span>
            </label>
            <label>
              <input type="radio" name="delivery" value="Consultar entrega por Instagram" />
              <span>Consultar entrega</span>
            </label>
          </div>
        </fieldset>

        <div class="order-summary" aria-live="polite">
          <div class="summary-heading">
            <span>Resumen de tu detalle</span>
            <strong>Maison Steff</strong>
          </div>
          <dl>
            <div><dt>Producto</dt><dd id="summary-product">Por elegir</dd></div>
            <div><dt>Relleno</dt><dd id="summary-filling">Chantilly sin recargo</dd></div>
            <div><dt>Cantidad</dt><dd id="summary-quantity">1</dd></div>
            <div><dt>Fecha</dt><dd id="summary-date">Por definir</dd></div>
            <div><dt>Ocasión</dt><dd id="summary-occasion">Cumpleaños</dd></div>
            <div><dt>Diseño</dt><dd id="summary-detail">Sin detalle especial</dd></div>
          </dl>
        </div>

        <p class="form-note">Copiaremos tu mensaje y te mostraremos cómo pegarlo antes de abrir Instagram. Si tienes una foto de referencia, puedes enviarla en ese chat para confirmar el diseño.</p>
        <div class="final-reservation-actions">
          <a
            class="button instagram-reservation-button"
            href={site.instagramDmUrl}
            target="_blank"
            rel="noreferrer"
            id="copy-open-instagram"
          >
            Copiar mensaje y continuar <span>→</span>
          </a>
          <div>
            <button class="text-button previous-step" type="button" data-previous="2"><span>←</span> Editar detalles</button>
            <button class="text-button reset-reservation" type="reset">Empezar de nuevo</button>
          </div>
        </div>
        <p class="copy-status" id="copy-status" role="status"></p>
      </section>
    </form>
  </div>

  <dialog class="paste-guide" id="paste-guide" aria-labelledby="paste-guide-title">
    <div class="paste-guide-card">
      <button class="paste-guide-close" type="button" aria-label="Cerrar indicación" data-close-paste-guide>×</button>
      <span class="paste-guide-icon" aria-hidden="true">✓</span>
      <p class="paste-guide-kicker">Mensaje copiado</p>
      <h2 id="paste-guide-title">Tu solicitud está lista.</h2>
      <p id="paste-guide-instruction">En Instagram, pega el mensaje en el chat y presiona enviar.</p>
      <div class="paste-guide-actions">
        <a class="button" href={site.instagramDmUrl} target="_blank" rel="noreferrer" id="open-instagram-after-copy">
          Abrir Instagram <span aria-hidden="true">↗</span>
        </a>
        <button class="text-button" type="button" data-close-paste-guide>Volver al resumen</button>
      </div>
    </div>
  </dialog>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("#reservation-form");
  const panels = [...document.querySelectorAll<HTMLElement>("[data-step-panel]")];
  const title = document.querySelector<HTMLElement>("#step-title");
  const counter = document.querySelector<HTMLElement>("#current-step");
  const progress = document.querySelector<HTMLElement>("#step-progress-bar");
  const status = document.querySelector<HTMLElement>("#copy-status");
  const pasteGuide = document.querySelector<HTMLDialogElement>("#paste-guide");
  const pasteInstruction = document.querySelector<HTMLElement>("#paste-guide-instruction");
  const quantity = document.querySelector<HTMLInputElement>("#quantity");
  const dateField = document.querySelector<HTMLInputElement>("#date");
  const productInputs = form ? [...form.querySelectorAll<HTMLInputElement>('input[name="product"]')] : [];
  const fillingInputs = form ? [...form.querySelectorAll<HTMLInputElement>('input[name="filling"]')] : [];
  const dateFormatter = new Intl.DateTimeFormat("es-HN", { dateStyle: "long", timeZone: "UTC" });
  const motionSafe = !window.matchMedia || !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const summaryElements: Record<string, HTMLElement | null> = {
    "summary-product": document.querySelector("#summary-product"),
    "summary-filling": document.querySelector("#summary-filling"),
    "summary-quantity": document.querySelector("#summary-quantity"),
    "summary-date": document.querySelector("#summary-date"),
    "summary-occasion": document.querySelector("#summary-occasion"),
    "summary-detail": document.querySelector("#summary-detail"),
  };
  const stepTitles = ["Elige tu favorito", "Personaliza tu detalle", "Revisa tu solicitud"];
  let activeStep = 1;

  if (dateField) {
    const today = new Date();
    today.setMinutes(today.getMinutes() - today.getTimezoneOffset());
    dateField.min = today.toISOString().split("T")[0];
  }

  const fieldForStep = (step: number) => {
    if (step === 1) return form ? form.querySelector<HTMLInputElement>('input[name="product"]:checked') : null;
    if (step === 2) return dateField && dateField.value ? dateField : null;
    return form ? form.querySelector<HTMLInputElement>("#customer-name") : null;
  };

  const canContinue = (step: number) => {
    if (step === 1 && !fieldForStep(1)) {
      const choiceGrid = form ? form.querySelector<HTMLElement>(".product-choice-grid") : null;
      if (choiceGrid) choiceGrid.classList.add("needs-attention");
      return false;
    }
    if (step === 2) {
      const invalidField = [quantity, dateField].find((field) => field && !field.checkValidity());
      if (invalidField) {
        invalidField.reportValidity();
        return false;
      }
    }
    return true;
  };

  const setStep = (step: number, focusHeading = true) => {
    activeStep = Math.max(1, Math.min(3, step));
    panels.forEach((panel) => {
      const active = Number(panel.dataset.stepPanel) === activeStep;
      panel.hidden = !active;
      panel.classList.toggle("active", active);
    });
    if (title) title.textContent = stepTitles[activeStep - 1];
    if (counter) counter.textContent = `0${activeStep}`;
    if (progress) progress.style.width = `${(activeStep / 3) * 100}%`;
    if (form) form.scrollIntoView({ behavior: motionSafe ? "smooth" : "auto", block: "center" });
    updateSummary();
    if (focusHeading) {
      requestAnimationFrame(() => {
        const activePanel = panels.find((panel) => Number(panel.dataset.stepPanel) === activeStep);
        const heading = activePanel ? activePanel.querySelector<HTMLElement>("h3") : null;
        if (heading) heading.focus({ preventScroll: true });
      });
    }
  };

  const formData = () => (form ? new FormData(form) : new FormData());

  const formatDate = (value: FormDataEntryValue | null) => {
    if (!value) return "Por definir";
    return dateFormatter.format(new Date(`${value.toString()}T00:00:00Z`));
  };

  const textValue = (value: FormDataEntryValue | null, fallback: string) => {
    return value ? value.toString() : fallback;
  };

  const selectedFilling = () => {
    const input = fillingInputs.find((item) => item.checked);
    const label = input ? input.value : "Chantilly";
    const surcharge = input ? Number(input.dataset.surcharge || 0) : 0;
    const summary = surcharge > 0 ? `${label} (+L ${surcharge} c/u)` : `${label} sin recargo`;
    return { label, surcharge, summary };
  };

  const syncProductChoices = () => {
    productInputs.forEach((input) => {
      const choice = input.closest(".product-choice");
      if (choice) choice.classList.toggle("is-selected", input.checked);
    });
  };

  const updateSummary = () => {
    const data = formData();
    const filling = selectedFilling();
    const values: Record<string, string> = {
      "summary-product": textValue(data.get("product"), "Por elegir"),
      "summary-filling": filling.summary,
      "summary-quantity": textValue(data.get("quantity"), "1"),
      "summary-date": formatDate(data.get("date")),
      "summary-occasion": textValue(data.get("occasion"), "Por definir"),
      "summary-detail": textValue(data.get("dedication"), "Sin detalle especial"),
    };
    Object.entries(values).forEach(([id, value]) => {
      const element = summaryElements[id];
      if (element) element.textContent = value;
    });
    if (status) status.textContent = "";
    syncProductChoices();
  };

  const buildMessage = () => {
    const data = formData();
    const product = data.get("product") || "un detalle";
    const quantityValue = Number(data.get("quantity") || 1);
    const occasion = (data.get("occasion") || "una ocasión especial").toString().toLowerCase();
    const filling = selectedFilling();
    const dedicationValue = data.get("dedication");
    const dedication = dedicationValue ? dedicationValue.toString().trim() : "";
    const delivery = data.get("delivery") === "Recoger"
      ? "Prefiero recogerlo."
      : "Me gustaría consultar la entrega.";
    const message = [
      "Hola Maison Steff, me gustaría reservar un detalle.",
      "",
      `Quiero ${product}.`,
      quantityValue === 1 ? "Sería una unidad." : `Serían ${quantityValue} unidades.`,
      filling.surcharge > 0
        ? `Relleno: ${filling.label} (+L ${filling.surcharge} por unidad).`
        : `Relleno: ${filling.label} sin recargo.`,
      `Lo necesito para el ${formatDate(data.get("date"))}.`,
      `La ocasión es un ${occasion}.`,
      ...(dedication ? [`Diseño o mensaje: ${dedication}.`] : ["Diseño o mensaje: lo podemos definir por Instagram."]),
      "Si tengo una imagen de referencia, la enviaré por Instagram para confirmar si se puede realizar.",
      "Entiendo que por ahora trabajan principalmente con chantilly y que las opciones con fondant o colores más vivos se consultarán más adelante.",
      delivery,
      `Mi nombre es ${data.get("customerName") || "Por definir"}.`,
      "",
      "¿Me confirman disponibilidad y precio final? Gracias.",
    ];
    return message.join("\n");
  };

  const copyMessage = async (message: string) => {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      await navigator.clipboard.writeText(message);
      return;
    }

    const textarea = document.createElement("textarea");
    textarea.value = message;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.opacity = "0";
    document.body.appendChild(textarea);
    textarea.select();
    const copied = document.execCommand("copy");
    textarea.remove();
    if (!copied) throw new Error("No se pudo copiar el mensaje");
  };

  const pasteHelp = () => {
    const touchDevice = window.matchMedia("(pointer: coarse)").matches || navigator.maxTouchPoints > 0;
    if (touchDevice) {
      return "En Instagram, mantén presionado el campo del mensaje, toca “Pegar” y después presiona enviar.";
    }
    if (/Macintosh|Mac OS X/.test(navigator.userAgent)) {
      return "En el chat de Instagram, presiona ⌘ + V o haz clic derecho y selecciona “Pegar”. Después presiona enviar.";
    }
    return "En el chat de Instagram, presiona Ctrl + V o haz clic derecho y selecciona “Pegar”. Después presiona enviar.";
  };

  const showPasteGuide = () => {
    if (!pasteGuide) return;
    if (typeof pasteGuide.showModal === "function") {
      pasteGuide.showModal();
      return;
    }
    pasteGuide.setAttribute("open", "");
  };

  const closePasteGuide = () => {
    if (!pasteGuide) return;
    if (typeof pasteGuide.close === "function") {
      pasteGuide.close();
      return;
    }
    pasteGuide.removeAttribute("open");
  };

  document.querySelectorAll<HTMLButtonElement>("[data-close-paste-guide]").forEach((button) => {
    button.addEventListener("click", closePasteGuide);
  });

  if (pasteGuide) pasteGuide.addEventListener("click", (event) => {
    if (event.target === pasteGuide) closePasteGuide();
  });

  const openInstagramAfterCopy = document.querySelector("#open-instagram-after-copy");
  if (openInstagramAfterCopy) openInstagramAfterCopy.addEventListener("click", () => {
    closePasteGuide();
    if (status) status.textContent = "Instagram abierto. Pega el mensaje copiado y presiona enviar.";
  });

  document.querySelectorAll<HTMLButtonElement>(".next-step").forEach((button) => {
    button.addEventListener("click", () => {
      if (canContinue(activeStep)) setStep(Number(button.dataset.next));
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".previous-step").forEach((button) => {
    button.addEventListener("click", () => setStep(Number(button.dataset.previous)));
  });

  document.querySelectorAll<HTMLButtonElement>("[data-quantity]").forEach((button) => {
    button.addEventListener("click", () => {
      if (!quantity) return;
      quantity.value = String(Math.max(1, Number(quantity.value || 1) + Number(button.dataset.quantity)));
      updateSummary();
    });
  });

  if (form) form.addEventListener("input", (event) => {
    if ((event.target as HTMLInputElement).name === "product") {
      const choiceGrid = form.querySelector(".product-choice-grid");
      if (choiceGrid) choiceGrid.classList.remove("needs-attention");
    }
    updateSummary();
  });

  if (form) form.addEventListener("reset", () => {
    setTimeout(() => setStep(1, false));
  });

  window.addEventListener("select-product", ((event: CustomEvent<string>) => {
    const product = productInputs.find((input) => input.value === event.detail);
    if (product) {
      product.checked = true;
      syncProductChoices();
      setStep(2);
    }
  }) as EventListener);

  const copyOpenInstagram = document.querySelector<HTMLAnchorElement>("#copy-open-instagram");
  if (copyOpenInstagram) copyOpenInstagram.addEventListener("click", (event) => {
    event.preventDefault();
    const customerName = form ? form.querySelector<HTMLInputElement>("#customer-name") : null;
    if (!customerName || !customerName.value.trim()) {
      if (customerName) customerName.reportValidity();
      return;
    }
    copyMessage(buildMessage()).then(
      () => {
        if (pasteInstruction) pasteInstruction.textContent = pasteHelp();
        if (status) status.textContent = "Mensaje copiado. Revisa la indicación para abrir Instagram.";
        showPasteGuide();
      },
      () => {
        if (status) status.textContent = "No pudimos copiar automáticamente. Revisa los datos e inténtalo nuevamente.";
      },
    );
  });

  updateSummary();
</script>
