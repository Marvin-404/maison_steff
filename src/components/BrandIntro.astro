---
import { withBase } from "../utils/asset";
---

<div class="brand-intro" id="brand-intro" aria-hidden="true">
  <div class="intro-aurora intro-aurora-one"></div>
  <div class="intro-aurora intro-aurora-two"></div>
  <div class="intro-glow"></div>
  <div class="intro-content">
    <div class="intro-logo-wrap">
      <span class="intro-ring intro-ring-one"></span>
      <span class="intro-ring intro-ring-two"></span>
      <img
        src={withBase("images/real/maison-steff-logo.png")}
        alt=""
        class="intro-logo"
      />
    </div>
    <p class="intro-name"><strong>Maison</strong> <em>Steff</em></p>
    <span class="intro-tagline">Pastelería boutique</span>
  </div>
  <div class="intro-scroll">
    <span>Desliza para descubrir</span>
    <i aria-hidden="true"></i>
  </div>
</div>
