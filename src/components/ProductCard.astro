---
import type { Product } from "../data/products";
import OptimizedPicture from "./OptimizedPicture.astro";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article
  class="product-card"
  data-product-id={product.id}
  data-product-price={product.basePrice}
  data-filters={product.filters.join(" ")}
  data-reveal
>
  <div class="product-image">
    <OptimizedPicture
      src={product.image}
      alt={product.alt}
      width="680"
      height="760"
      loading="lazy"
      sizes="(min-width: 64rem) 24rem, (min-width: 42rem) 45vw, 82vw"
    />
    <span class="product-badge">{product.badge}</span>
  </div>
  <div class="product-content">
    <p class="product-category">{product.category}</p>
    <h3>{product.name}</h3>
    <p>{product.description}</p>
    <div class="product-footer">
      <strong>{product.price}</strong>
      <button
        class="text-button reserve-product"
        type="button"
        data-product={product.name}
        data-product-price={product.basePrice}
      >
        Reservar este <span aria-hidden="true">↗</span>
      </button>
    </div>
  </div>
</article>
