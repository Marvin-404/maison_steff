---
import { site } from "../data/site";
import { withBase } from "../utils/asset";
---

<div class="progress-bar" aria-hidden="true"><span id="page-progress"></span></div>
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="#inicio" aria-label="Maison Steff, ir al inicio">
      <img src={withBase("images/real/maison-steff-logo.png")} alt="" width="520" height="520" />
      <span>
        <strong>Maison</strong>
        <em>Steff</em>
      </span>
    </a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="main-nav" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
    <nav class="main-nav" id="main-nav" aria-label="Navegación principal">
      <a href="#catalogo">Catálogo</a>
      <a href="#reservar">Reservar</a>
      <a href={site.instagramUrl} target="_blank" rel="noreferrer">Instagram</a>
    </nav>
    <a class="button button-small header-cta" href={site.instagramDmUrl} target="_blank" rel="noreferrer">
      Pedir por Instagram
    </a>
  </div>
</header>

<script>
  const menu = document.querySelector<HTMLElement>("#main-nav");
  const menuToggle = document.querySelector<HTMLButtonElement>(".menu-toggle");

  const closeMenu = () => {
    menu?.classList.remove("open");
    menuToggle?.setAttribute("aria-expanded", "false");
  };

  menuToggle?.addEventListener("click", () => {
    const open = !menu?.classList.contains("open");
    menu?.classList.toggle("open", open);
    menuToggle.setAttribute("aria-expanded", String(open));
  });

  menu?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));
  document.addEventListener("keydown", (event) => event.key === "Escape" && closeMenu());
</script>
