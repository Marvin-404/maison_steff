---
import { withBase } from "../utils/asset";
import { galleryItems } from "../data/gallery";

const layoutClass = {
  standard: "",
  tall: "gallery-tall",
  wide: "gallery-wide",
};
---

<section class="section gallery-section" id="galeria" aria-labelledby="gallery-title">
  <div class="container">
    <div class="section-heading split-heading" data-reveal>
      <div>
        <p class="eyebrow">Galería Maison</p>
        <h2 id="gallery-title">Detalles dulces que se recuerdan.</h2>
      </div>
      <p>Sabores y presentaciones hechas para emocionar.</p>
    </div>
    <div class="gallery-grid">
      {galleryItems.map((item) => (
        <figure class:list={["gallery-item", layoutClass[item.layout ?? "standard"]]} data-gallery-id={item.id} data-reveal>
          <img src={withBase(item.image)} alt={item.alt} width="720" height="760" loading="lazy" />
          <figcaption>{item.text}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
